# ============================================================
#  Qryptix — environment variables
#  Copy to .env.local and fill in. Leave Supabase blank to run
#  in preview/mock mode (no auth, no DB, no payments).
# ============================================================

# ---------- Supabase (auth + DB) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Required for verified purchases
# (the /api/purchase insert uses the service role after on-chain verification).
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Purchase flow gating ----------
# testnet (default/safe) targets Base Sepolia; mainnet targets Base.
NEXT_PUBLIC_CHAIN_MODE=testnet
# Keep false until: contract audited + entity finalized + multisig treasury
# live + a Base Sepolia purchase has been verified end-to-end.
NEXT_PUBLIC_BUY_FLOW_ENABLED=false

# ---------- Treasury (REQUIRED before enabling purchases) ----------
# Public — used by the UI and as the on-chain USDC payment recipient.
# Prefer a multisig (e.g. Safe). Must NOT be the zero address.
NEXT_PUBLIC_TREASURY_WALLET=
# Optional server-side override (takes precedence in verification).
TREASURY_WALLET=

# ---------- RPC endpoints ----------
# Client (wallet) RPCs:
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Server (verification) RPCs — use a private/rate-limited provider in prod:
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ---------- WalletConnect (optional) ----------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---------- Brevo (reservation emails — optional) ----------
BREVO_API_KEY=
BREVO_RESERVATION_LIST_ID=

# Note: USDC addresses are configured per-network in lib/chains.ts and
# lib/server/onchain.ts (mainnet + Base Sepolia). No env var needed.
