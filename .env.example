# ============================================================
#  Qryptix — Environment variables
# ============================================================

# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never exposed to client

# --- Brevo (newsletter / reservations, you already use this) ---
BREVO_API_KEY=
BREVO_RESERVATION_LIST_ID=

# --- Buy flow (Stage 3) ---
# Set to "true" ONLY after audit + entity + multisig are live
NEXT_PUBLIC_BUY_FLOW_ENABLED=false

# --- Wallet / chain (Stage 3) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_TREASURY_WALLET=
# Optional payment token contracts on Base
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_USDT_ADDRESS=
